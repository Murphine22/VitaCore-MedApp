{
  "name": "vitacore-medapp",
  "version": "1.0.0",
  "private": true,
  "description": "VitaCore — Full-Stack Hospital Management System (React + Vite client, Express + MongoDB API)",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "concurrently -n SERVER,CLIENT -c magenta,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "start": "npm --prefix server start",
    "build": "npm --prefix client run build",
    "lint": "npm --prefix client run lint",
    "seed": "npm --prefix server run seed",
    "test": "npm --prefix server test",
    "install:all": "npm install && npm --prefix server install && npm --prefix client install"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
