# ──────────────────────────────────────────────────────────────
# VitaCore — Root environment sample
# Copy this file to server/.env and client/.env and adjust values.
# This root file documents every variable used across the stack.
# ──────────────────────────────────────────────────────────────

# ===== SERVER (server/.env) =====
# Port the Express API listens on
PORT=5000
# Node environment: development | production | test
NODE_ENV=development
# MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/vitacore
# Secret used to sign JWT access tokens (use a long random string in prod)
JWT_SECRET=super_secret_change_me
# JWT token lifetime
JWT_EXPIRES_IN=7d
# Comma-separated list of allowed CORS origins
CLIENT_ORIGIN=http://localhost:3000

# ===== CLIENT (client/.env) =====
# Base URL of the VitaCore API
VITE_API_URL=http://localhost:5000/api
# "true" => talk to the real API, "false" => run standalone demo mode (localStorage)
VITE_USE_API=false
